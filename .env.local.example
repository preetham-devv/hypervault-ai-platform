# ============================================================
# HyperVault AI Platform — Local Development Environment
# ============================================================
# Copy this file to .env.local (gitignored) and fill in values.
#
#   cp .env.local.example .env.local
#
# This config points at the Docker Compose postgres service.
# Do NOT use these credentials outside of local development.
# ============================================================

# ── Database ──────────────────────────────────────────────────────────────────
# The `db` hostname resolves inside Docker Compose to the postgres container.
# Leave ALLOYDB_CONNECTION_NAME blank so config.py uses the direct TCP path.
ALLOYDB_IP=db
ALLOYDB_DATABASE=hr_platform
ALLOYDB_USER=hypervault_app
ALLOYDB_PASSWORD=localdev_app
# Empty → use direct TCP (no Cloud SQL Connector, no IAM auth)
ALLOYDB_CONNECTION_NAME=

# If you want to connect as postgres (superuser) instead — note that postgres
# superusers bypass RLS, so RLS policies will NOT be enforced in that case:
# ALLOYDB_USER=postgres
# ALLOYDB_PASSWORD=localdev

# ── Google Cloud (optional in local dev) ─────────────────────────────────────
# Required only for Gemini / Vertex AI calls and vector embeddings.
# Run `gcloud auth application-default login` to set up ADC on your machine,
# then mount the credentials into the container or set them here.
#
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_GENAI_USE_VERTEXAI=True

# ── AlloyDB cluster identifiers (not needed for local docker postgres) ────────
# ALLOYDB_CLUSTER=ai-platform-cluster
# ALLOYDB_INSTANCE=ai-platform-primary
# ALLOYDB_REGION=us-central1

# ── Vertex AI / Gemini ────────────────────────────────────────────────────────
VERTEX_AI_MODEL=gemini-2.0-flash
VERTEX_AI_EMBEDDING_MODEL=text-embedding-005
VERTEX_AI_ENDPOINT_REGION=us-central1

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=DEBUG
APP_VERSION=dev

# The frontend calls the API via this URL.
# In Docker Compose the api service is reachable via its service name.
API_BASE_URL=http://api:8080

# ── Observability ─────────────────────────────────────────────────────────────
# console → pretty-print spans/metrics to stdout (good for local dev).
# gcp     → send to Cloud Trace / Cloud Monitoring (requires GOOGLE_CLOUD_PROJECT).
OTEL_EXPORTER_TYPE=console
OTEL_METRIC_EXPORT_INTERVAL_MS=60000

# ── Database connection timeout ───────────────────────────────────────────────
DB_CONNECT_TIMEOUT=30

# ── Cloud Run (only used by make deploy) ─────────────────────────────────────
# CLOUD_RUN_SERVICE_NAME=hypervault-ai-platform
# CLOUD_RUN_REGION=us-central1
# CLOUD_RUN_SERVICE_ACCOUNT=ai-platform-sa@your-project.iam.gserviceaccount.com
# CLOUD_RUN_URL=https://hypervault-ai-platform-xxxx-uc.a.run.app
