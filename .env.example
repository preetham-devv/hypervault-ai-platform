# ============================================================
# AlloyDB AI Platform — Environment Configuration
# Copy to .env and fill in your values. NEVER commit .env.
# ============================================================

# --- Google Cloud ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=True

# --- AlloyDB ---
ALLOYDB_CLUSTER=ai-platform-cluster
ALLOYDB_INSTANCE=ai-platform-primary
ALLOYDB_REGION=us-central1
ALLOYDB_DATABASE=hr_platform
ALLOYDB_USER=postgres
ALLOYDB_PASSWORD=your-secure-password-here
ALLOYDB_IP=10.0.0.2
ALLOYDB_CONNECTION_NAME=projects/your-project/locations/us-central1/clusters/ai-platform-cluster/instances/ai-platform-primary

# --- Vertex AI ---
VERTEX_AI_MODEL=gemini-2.0-flash
VERTEX_AI_EMBEDDING_MODEL=text-embedding-005
VERTEX_AI_ENDPOINT_REGION=us-central1

# --- App ---
APP_ENV=development
APP_PORT=8501
LOG_LEVEL=INFO

# --- Observability ---
# OTEL_EXPORTER_TYPE controls where traces and metrics are sent.
# Options:
#   console  — pretty-print to stdout (default, recommended for local dev)
#   gcp      — send to Cloud Trace / Cloud Monitoring (use on Cloud Run)
OTEL_EXPORTER_TYPE=console
# How often the metric reader flushes data (milliseconds). Default: 60 000 ms.
OTEL_METRIC_EXPORT_INTERVAL_MS=60000

# --- Cloud Run ---
CLOUD_RUN_SERVICE_NAME=alloydb-ai-platform
CLOUD_RUN_REGION=us-central1
CLOUD_RUN_SERVICE_ACCOUNT=ai-platform-sa@your-project.iam.gserviceaccount.com

# --- VPC ---
VPC_NETWORK=default
PRIVATE_IP_RANGE=alloydb-psa-range
